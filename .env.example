# =============================================================================
# Merch Makers - Environment Variables
# =============================================================================
# Copy this file to .env.local:  cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
# Local dev (via `supabase start`):
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_anon_key_from_supabase_status

# Service role key (for scripts/seed, NOT exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_from_supabase_status

# Database URL (used by e2e test setup only, NOT used at runtime)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# -----------------------------------------------------------------------------
# Stripe (client-side publishable key)
# -----------------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# -----------------------------------------------------------------------------
# App URL
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:3000

# =============================================================================
# Supabase Edge Function Secrets (set via `supabase secrets set`)
# These are NOT in .env.local — they go in Supabase's secret store.
# =============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# ASCOLOUR_API_URL=https://api.ascolour.com/v1
# ASCOLOUR_SUBSCRIPTION_KEY=your_key
# ASCOLOUR_EMAIL=your_email
# ASCOLOUR_PASSWORD=your_password
# RESEND_API_KEY=your_key
# CRM_WEBHOOK_URL=your_url
# APP_URL=http://localhost:3000
